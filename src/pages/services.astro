---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import necessary images
import onboarding from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import support from '@images/before-after.avif';
import businessDash from '@images/construction-workers.avif';
import compliance from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import progressBuilding from '@images/progress-building.avif';
import security from '@images/under-construction.avif';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Fast & Simple Account Setup',
    subTitle:
      'Getting started with AlphaPay takes less than 5 minutes. Our guided onboarding walks you through KYC identity verification, wallet creation, and linking your bank account or mobile money number. Our team is available 24/7 to help individuals and businesses get fully set up and transacting on day one.',
    single: false,
    imgOne: onboarding,
    imgOneAlt: 'AlphaPay team helping a new user onboard with KYC verification on laptop.',
    imgTwo: personWorking,
    imgTwoAlt: 'Developer integrating the AlphaPay payment API on a dual-monitor setup.',
  },
  {
    isRightSection: false,
    title: '24/7 Customer Support',
    subTitle:
      'Our dedicated support agents are available around the clock via live chat, email, and phone. Whether you have a stuck transfer, a billing question, or need help navigating a feature, our team in Accra is always ready to resolve your issue in under 2 hours — guaranteed.',
    img: support,
    imgAlt: 'Friendly AlphaPay customer support agent at modern call center in Accra.',
    btnExists: true,
    btnTitle: 'Contact Support',
    btnURL: '/contact',
  },
  {
    isRightSection: true,
    title: 'Business Payments & Payroll',
    subTitle:
      'AlphaPay for Business gives merchants and enterprises full control over their finances. Send bulk payroll disbursements to hundreds of employees in seconds, collect payments via our checkout API, and get deep analytics on your revenue, settlement times, and transaction success rates — all from one intuitive dashboard.',
    single: false,
    imgOne: businessDash,
    imgOneAlt: 'African business owner reviewing payroll and analytics on tablet.',
    imgTwo: compliance,
    imgTwoAlt: 'African fintech AML and KYC regulatory compliance framework diagram.',
  },
  {
    isRightSection: false,
    title: 'Developer API & Integrations',
    subTitle:
      'Our RESTful Payment API lets developers integrate AlphaPay into any platform in hours, not weeks. Comprehensive documentation, sandbox environments, webhook support, and SDKs for popular frameworks are all available. Accept payments, initiate transfers, and query balances programmatically with full API key management from your dashboard.',
    img: personWorking,
    imgAlt: 'Developer working with the AlphaPay Payment Gateway API and webhook logs.',
    btnExists: true,
    btnTitle: 'View API Docs',
    btnURL: '#',
  },
  {
    isRightSection: true,
    title: 'Regulatory Compliance & Security',
    subTitle:
      'AlphaPay is fully compliant with the Bank of Ghana (BoG), the Central Bank of Nigeria (CBN), and other African regulatory bodies. We implement AML transaction monitoring, KYC identity verification, biometric authentication, and real-time fraud detection — all running on a highly available AWS infrastructure secured behind an Application Load Balancer with ACM SSL.',
    single: false,
    imgOne: compliance,
    imgOneAlt: 'African fintech regulatory compliance shield with AML and KYC workflow.',
    imgTwo: security,
    imgTwoAlt: 'AWS cloud security infrastructure protecting AlphaPay transactions.',
    btnExists: true,
    btnTitle: 'Learn about security',
    btnURL: '#',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'AlphaPay offers fast onboarding, 24/7 support, business payroll, payment APIs, and full regulatory compliance across Africa.';
const ogTitle = 'AlphaPay Services | African Fintech Payment Platform';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': '#!',
    '@type': '#!',
    '@id': '#!',
    url: '#!',
    name: '#!',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: '#!',
      name: 'AlphaPay',
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <MainSection
    title="Everything You Need to Move Money"
    subTitle="AlphaPay provides end-to-end financial services — from instant personal transfers and virtual cards to enterprise payment APIs and regulatory compliance — all built on a robust AWS cloud infrastructure."
    btnExists={true}
    btnTitle="Get Started Free"
    btnURL="#"
  />
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <FeaturesStats
    title="AlphaPay by the Numbers"
    subTitle="Our commitment to speed, reliability, and security is reflected in the numbers. Every transaction processed by AlphaPay runs on enterprise-grade AWS infrastructure with 99.99% uptime."
    mainStatTitle="500k+"
    mainStatSubTitle="active users sending and receiving money daily across Africa"
    stats={[
      {
        stat: '99.99%',
        description: 'platform uptime on AWS infrastructure',
      },
      {
        stat: '<2 sec',
        description: 'average transfer time to banks and wallets',
      },
      {
        stat: '15+',
        description: 'African countries with instant settlement',
      },
    ]}
  />
</MainLayout>
