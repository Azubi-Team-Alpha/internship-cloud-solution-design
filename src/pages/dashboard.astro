---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `Dashboard | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  {/* Auth guard — content shown only after JS validates session */}
  <div id="dashboard-root" class="hidden">

    {/* ── Welcome bar ──────────────────────────────────────────────────────── */}
    <div class="border-b border-neutral-200/80 bg-yellow-50 dark:border-neutral-700 dark:bg-neutral-900">
      <div class="mx-auto max-w-[85rem] px-4 py-4 sm:px-6 lg:px-8 2xl:max-w-full">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-yellow-600 dark:text-yellow-500">
              Welcome back 👋
            </p>
            <h2 id="user-greeting" class="text-xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200">
              Loading…
            </h2>
          </div>
          <div class="flex items-center gap-2">
            <span
              id="account-badge"
              class="hidden rounded-full border border-yellow-300 bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-800 dark:border-yellow-600/40 dark:bg-yellow-900/20 dark:text-yellow-400"
            >
              Personal
            </span>
            <button
              id="logout-btn"
              class="inline-flex items-center gap-x-2 rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-2 text-xs font-semibold text-neutral-700 transition duration-300 hover:bg-neutral-200 focus-visible:ring-3 outline-hidden ring-zinc-500 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700"
            >
              Sign out
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-10 2xl:max-w-full">

      {/* ── Balance + Quick Actions ──────────────────────────────────────────── */}
      <div class="mb-8 grid gap-6 lg:grid-cols-3">

        {/* Balance card */}
        <div class="col-span-1 rounded-xl border border-neutral-200 bg-neutral-100 p-6 shadow-xs dark:border-neutral-700 dark:bg-neutral-800 lg:col-span-2">
          <div class="flex items-start justify-between">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-neutral-500 dark:text-neutral-400">
                Total Balance
              </span>
              <p id="user-balance" class="mt-1 text-4xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-200">
                GH₵ 0.00
              </p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                ≈ $0 USD &nbsp;·&nbsp;
                <span class="font-medium text-green-600 dark:text-green-500">+12.4% this month</span>
              </p>
            </div>
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-neutral-200 bg-yellow-400 text-neutral-800 dark:border-neutral-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
          </div>

          <div class="mt-6 border-t border-neutral-200 pt-5 dark:border-neutral-700">
            <div class="flex justify-around">
              {[
                { label: 'Send', icon: '↑', action: 'send' },
                { label: 'Receive', icon: '↓', action: 'receive' },
                { label: 'Top Up', icon: '+', action: 'topup' },
                { label: 'History', icon: '≡', action: 'history' },
              ].map(btn => (
                <button
                  data-action={btn.action}
                  class="quick-action flex flex-col items-center gap-1.5 group cursor-pointer"
                >
                  <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-neutral-200 bg-yellow-50 text-neutral-800 font-bold text-lg transition duration-300 group-hover:bg-yellow-400 group-hover:border-yellow-400 dark:border-neutral-600 dark:bg-neutral-700 dark:text-neutral-200 dark:group-hover:bg-yellow-400 dark:group-hover:text-neutral-800">
                    {btn.icon}
                  </div>
                  <span class="text-[11px] font-semibold text-neutral-600 dark:text-neutral-400">{btn.label}</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        {/* Stats card */}
        <div class="col-span-1 rounded-xl border border-neutral-200 bg-neutral-100 p-6 shadow-xs dark:border-neutral-700 dark:bg-neutral-800">
          <h3 class="mb-4 text-sm font-bold text-neutral-700 dark:text-neutral-300">This Month</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 bg-neutral-50 text-sm font-bold text-green-600 dark:border-neutral-600 dark:bg-neutral-700">↓</div>
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Money In</span>
              </div>
              <span class="text-sm font-bold text-green-600 dark:text-green-500">+GH₵ 6,200</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 bg-neutral-50 text-sm font-bold text-red-500 dark:border-neutral-600 dark:bg-neutral-700">↑</div>
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Money Out</span>
              </div>
              <span class="text-sm font-bold text-red-500 dark:text-red-400">-GH₵ 1,380</span>
            </div>
            <div class="border-t border-neutral-200 pt-3 dark:border-neutral-700">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Net savings</span>
                <span class="text-sm font-bold text-neutral-800 dark:text-neutral-200">GH₵ 4,820</span>
              </div>
            </div>
            <div>
              <div class="mb-1 flex justify-between text-xs text-neutral-500 dark:text-neutral-400">
                <span>Monthly goal</span><span>78%</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-neutral-200 dark:bg-neutral-700">
                <div class="h-2 rounded-full bg-yellow-400" style="width: 78%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* ── Main Grid ────────────────────────────────────────────────────────── */}
      <div class="grid gap-6 lg:grid-cols-3">

        {/* Recent Transactions */}
        <div class="col-span-1 rounded-xl border border-neutral-200 bg-neutral-100 shadow-xs dark:border-neutral-700 dark:bg-neutral-800 lg:col-span-2">
          <div class="flex items-center justify-between border-b border-neutral-200 px-6 py-4 dark:border-neutral-700">
            <h3 class="font-bold text-neutral-800 dark:text-neutral-200">Recent Transactions</h3>
            <button class="text-xs font-semibold text-orange-400 hover:underline dark:text-orange-400">View all</button>
          </div>
          <div class="px-4 sm:px-6">
            {[
              { initials: 'KA', name: 'Kofi Agyeman', time: 'Today, 10:24 AM', amount: '+GH₵ 500', type: 'in', note: 'Freelance payment' },
              { initials: 'AB', name: 'Ama Boateng', time: 'Yesterday, 3:11 PM', amount: '-GH₵ 150', type: 'out', note: 'Lunch split' },
              { initials: 'MM', name: 'MTN MoMo', time: 'Mon, 9:00 AM', amount: '+GH₵ 1,200', type: 'in', note: 'Wallet top-up' },
              { initials: 'DY', name: 'David Yirenkyi', time: 'Sun, 2:45 PM', amount: '-GH₵ 75', type: 'out', note: 'Shared taxi' },
              { initials: 'ZA', name: 'Zakaria Adeeba', time: 'Sat, 11:30 AM', amount: '+GH₵ 320', type: 'in', note: 'Debt repayment' },
            ].map(tx => (
              <div class="flex items-center justify-between py-3 border-b border-neutral-200/60 last:border-0 dark:border-neutral-700/60 hover:bg-neutral-100/50 dark:hover:bg-neutral-800/30 -mx-2 px-2 rounded-xl transition cursor-pointer">
                <div class="flex items-center gap-3">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-neutral-200 bg-neutral-50 text-xs font-bold text-neutral-700 dark:border-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                    {tx.initials}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-200">{tx.name}</p>
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400">{tx.note} · {tx.time}</p>
                  </div>
                </div>
                <span class={`text-sm font-bold ${tx.type === 'in' ? 'text-green-600 dark:text-green-500' : 'text-red-500 dark:text-red-400'}`}>
                  {tx.amount}
                </span>
              </div>
            ))}
          </div>
        </div>

        {/* Right column */}
        <div class="col-span-1 flex flex-col gap-6">

          {/* Quick Send */}
          <div class="rounded-xl border border-neutral-200 bg-neutral-100 p-6 shadow-xs dark:border-neutral-700 dark:bg-neutral-800">
            <h3 class="mb-4 font-bold text-neutral-800 dark:text-neutral-200">Quick Send</h3>
            <div class="grid gap-y-3">
              <div>
                <label for="send-recipient" class="mb-2 block text-sm text-neutral-800 dark:text-neutral-200">Recipient</label>
                <input type="text" id="send-recipient" placeholder="Name, email, or phone"
                  class="block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 focus:border-neutral-200 focus:ring-3 focus:ring-neutral-400 focus:outline-hidden dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:focus:ring-1" />
              </div>
              <div>
                <label for="send-amount" class="mb-2 block text-sm text-neutral-800 dark:text-neutral-200">Amount (GH₵)</label>
                <input type="number" id="send-amount" placeholder="0.00" min="1"
                  class="block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 focus:border-neutral-200 focus:ring-3 focus:ring-neutral-400 focus:outline-hidden dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:focus:ring-1" />
              </div>
              <button id="send-btn"
                class="inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-yellow-400 px-4 py-3 text-sm font-bold text-neutral-700 transition duration-300 hover:bg-yellow-500 focus-visible:ring-3 outline-hidden ring-zinc-500 dark:focus:outline-hidden disabled:pointer-events-none disabled:opacity-50">
                Send Money →
              </button>
              <div id="send-feedback" class="hidden rounded-lg border border-green-200 bg-green-50 p-3 text-xs text-green-700 dark:border-green-500/30 dark:bg-green-900/20 dark:text-green-400">
                ✅ Transfer sent successfully!
              </div>
            </div>
          </div>

          {/* Security Status */}
          <div class="rounded-xl border border-neutral-200 bg-neutral-100 p-6 shadow-xs dark:border-neutral-700 dark:bg-neutral-800">
            <h3 class="mb-4 flex items-center gap-2 font-bold text-neutral-800 dark:text-neutral-200">
              🛡️ Account Security
            </h3>
            <div class="space-y-3">
              {[
                { label: 'HTTPS Secured', ok: true, status: 'Active' },
                { label: 'Email verified', ok: true, status: 'Active' },
                { label: 'KYC status', ok: false, status: 'Pending' },
                { label: 'PIN set', ok: true, status: 'Active' },
              ].map(item => (
                <div class="flex items-center justify-between py-1 border-b border-neutral-200/60 last:border-0 dark:border-neutral-700/60">
                  <span class="text-sm text-neutral-700 dark:text-neutral-300">{item.label}</span>
                  {item.ok
                    ? <span class="rounded-md bg-green-100 px-2 py-0.5 text-[10px] font-bold text-green-800 dark:bg-green-900/30 dark:text-green-400">✅ {item.status}</span>
                    : <span class="rounded-md bg-yellow-100 px-2 py-0.5 text-[10px] font-bold text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">⚠ {item.status}</span>
                  }
                </div>
              ))}
            </div>
          </div>

          {/* Linked Wallets */}
          <div class="rounded-xl border border-neutral-200 bg-neutral-100 p-6 shadow-xs dark:border-neutral-700 dark:bg-neutral-800">
            <h3 class="mb-3 font-bold text-neutral-800 dark:text-neutral-200">Linked Wallets</h3>
            <div class="space-y-2">
              {[
                { name: 'MTN MoMo', num: '024 *** 456', dot: 'bg-yellow-400' },
                { name: 'Telecel Cash', num: '050 *** 789', dot: 'bg-red-500' },
              ].map(w => (
                <div class="flex items-center gap-3 rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 dark:border-neutral-600 dark:bg-neutral-700/30">
                  <div class={`h-2.5 w-2.5 shrink-0 rounded-full ${w.dot}`}></div>
                  <div class="min-w-0">
                    <p class="text-xs font-semibold text-neutral-800 dark:text-neutral-200">{w.name}</p>
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400">{w.num}</p>
                  </div>
                </div>
              ))}
              <button class="inline-flex w-full items-center justify-center gap-x-1 rounded-lg border border-dashed border-neutral-300 py-2.5 text-xs font-semibold text-neutral-500 transition hover:border-yellow-400 hover:text-yellow-600 dark:border-neutral-600 dark:text-neutral-400 dark:hover:border-yellow-500 dark:hover:text-yellow-400">
                + Link wallet
              </button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  {/* Action modal */}
  <div id="action-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-neutral-900/70 p-4">
    <div class="w-full max-w-sm rounded-xl border border-neutral-200 bg-neutral-100 p-7 shadow-xl dark:border-neutral-700 dark:bg-neutral-800">
      <h3 id="modal-title" class="mb-2 text-lg font-bold text-neutral-800 dark:text-neutral-200">Action</h3>
      <p id="modal-body" class="text-sm text-neutral-600 dark:text-neutral-400"></p>
      <button id="modal-close"
        class="mt-5 inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-yellow-400 px-4 py-3 text-sm font-bold text-neutral-700 transition duration-300 hover:bg-yellow-500 focus-visible:ring-3 outline-hidden ring-zinc-500">
        Close
      </button>
    </div>
  </div>
</MainLayout>

<script>
  // ── Auth guard ────────────────────────────────────────────────────────────────
  const rawUser = localStorage.getItem('alphapay_user');
  if (!rawUser) {
    window.location.href = '/signin';
  } else {
    const user = JSON.parse(rawUser);
    document.getElementById('dashboard-root')!.classList.remove('hidden');

    document.getElementById('user-greeting')!.textContent = `Hello, ${user.name}!`;
    document.getElementById('user-balance')!.textContent = user.balance || 'GH₵ 0.00';

    if (user.accountType) {
      const badge = document.getElementById('account-badge')!;
      badge.textContent = user.accountType === 'business' ? '🏢 Business' : '👤 Personal';
      badge.classList.remove('hidden');
    }
  }

  // ── Sign out ──────────────────────────────────────────────────────────────────
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('alphapay_user');
    window.location.href = '/';
  });

  // ── Quick action modal ────────────────────────────────────────────────────────
  const modalEl = document.getElementById('action-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalBody = document.getElementById('modal-body')!;

  const actionInfo: Record<string, { title: string; body: string }> = {
    send:    { title: '💸 Send Money',    body: 'Use the Quick Send card to transfer money instantly.' },
    receive: { title: '📥 Receive Money', body: 'Share your AlphaPay ID to receive money from anyone.' },
    topup:   { title: '💳 Top Up Wallet', body: 'Link a bank card or mobile money wallet to add funds.' },
    history: { title: '📊 Full History',  body: 'Statement download and filtering available in the full release.' },
  };

  document.querySelectorAll('.quick-action').forEach(btn => {
    btn.addEventListener('click', () => {
      const info = actionInfo[btn.getAttribute('data-action') || 'send'];
      modalTitle.textContent = info.title;
      modalBody.textContent = info.body;
      modalEl.classList.remove('hidden');
      modalEl.classList.add('flex');
    });
  });

  const closeModal = () => { modalEl.classList.add('hidden'); modalEl.classList.remove('flex'); };
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  modalEl.addEventListener('click', e => { if (e.target === modalEl) closeModal(); });

  // ── Quick Send ────────────────────────────────────────────────────────────────
  document.getElementById('send-btn')?.addEventListener('click', async () => {
    const recipient = (document.getElementById('send-recipient') as HTMLInputElement).value.trim();
    const amount = (document.getElementById('send-amount') as HTMLInputElement).value;
    if (!recipient || !amount || Number(amount) <= 0) { alert('Enter a valid recipient and amount.'); return; }

    const btn = document.getElementById('send-btn') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;
    await new Promise(r => setTimeout(r, 1200));

    document.getElementById('send-feedback')!.classList.remove('hidden');
    (document.getElementById('send-recipient') as HTMLInputElement).value = '';
    (document.getElementById('send-amount') as HTMLInputElement).value = '';
    btn.textContent = 'Send Money →';
    btn.disabled = false;
    setTimeout(() => document.getElementById('send-feedback')!.classList.add('hidden'), 3000);
  });
</script>
