---
const { title = 'Log in' } = Astro.props;

interface Props {
  title?: string;
}
---

<div class="flex items-center gap-x-3 md:my-4 md:border-s md:border-neutral-300 md:ps-6 dark:border-neutral-700">
  <a
    href="/signin/"
    class="flex items-center gap-x-2 text-base md:text-sm font-medium text-neutral-600 ring-zinc-500 transition duration-300 hover:text-blue-600 focus-visible:ring-3 outline-hidden dark:text-neutral-400 dark:ring-zinc-200 dark:hover:text-blue-400 2xl:text-base"
  >
    <svg class="h-4 w-4 shrink-0" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
    {title}
  </a>
  <a
    href="/signup/"
    class="rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-4 py-2 text-xs font-bold text-white shadow-sm shadow-blue-500/20 transition hover:from-blue-500 hover:to-indigo-500 hover:shadow-md active:scale-[0.98]"
  >
    Get Started
  </a>
</div>
