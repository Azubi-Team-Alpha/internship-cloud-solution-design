# ==============================================================================
# AlphaPay Environment Variables & Deployment Secrets Config
# ==============================================================================
# Copy this file to '.env' for local development.
# IMPORTANT: To prevent your GitHub Actions deployment pipelines from failing,
# you must configure the secrets listed below in your GitHub Repository settings
# under: Settings -> Secrets and variables -> Actions
# ==============================================================================

# ── LOCAL INTEGRATION KEYS ───────────────────────────────────────────────────
# Used for local SDK, testing, and mock payments integration.
ALPHAPAY_PUBLIC_KEY=pk_test_51...
ALPHAPAY_SECRET_KEY=sk_test_51...

# ── S3 STATIC HOSTING PIPELINE SECRETS ───────────────────────────────────────
# [Required in GitHub Secrets for S3 Pipeline]
# AWS credentials for IAM user with S3 & CloudFront permissions:
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# [Optional in GitHub Secrets - defaults will be used if not set]
AWS_REGION=us-east-1
S3_BUCKET=alphapay-africa-static

# [Optional in GitHub Secrets - set if using CloudFront CDN]
# If left blank, CDN invalidation step will be skipped:
CLOUDFRONT_DISTRIBUTION_ID=your_cloudfront_distribution_id

# ── EC2 VIRTUAL SERVER PIPELINE SECRETS ──────────────────────────────────────
# [Required in GitHub Secrets for EC2 Pipeline]
# Public IP address or domain name of your EC2 host:
EC2_HOST=your_ec2_public_ip

# [Optional in GitHub Secrets - defaults to 'ubuntu']
EC2_USERNAME=ubuntu

# [Required in GitHub Secrets for EC2 Pipeline]
# Content of your private SSH key (.pem file) to connect to EC2:
EC2_SSH_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
